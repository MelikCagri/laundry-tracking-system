generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  phone     String   @unique
  createdAt DateTime @default(now())

  // Relations
  activeMachines Machine[]
  logs           Log[]
  queueEntries   Queue[]
}

enum MachineStatus {
  BOS
  DOLU
  BITTI
  BOZUK
}

enum MachineType {
  WASHER
  DRYER
}

enum Block {
  A
  B
}

model Machine {
  id              String        @id @default(uuid())
  block           Block
  floor           Int
  type            MachineType
  status          MachineStatus @default(BOS)
  activeUserId    String?
  endTime         DateTime?
  durationMinutes Int?
  userNote        String?

  // Relations
  activeUser     User?         @relation(fields: [activeUserId], references: [id])
  logs           Log[]
  queueEntries   Queue[]
}

enum ActionType {
  START
  EXTEND
  REPORT_BROKEN
  REPORT_FULL
  FINISH
}

model Log {
  id         String     @id @default(uuid())
  userId     String
  machineId  String
  actionType ActionType
  createdAt  DateTime   @default(now())

  // Relations
  user       User       @relation(fields: [userId], references: [id])
  machine    Machine    @relation(fields: [machineId], references: [id])
}

enum QueueStatus {
  WAITING
  COMPLETED
  CANCELLED
  SKIPPED
}

model Queue {
  id         String      @id @default(uuid())
  machineId  String
  userId     String
  joinedAt   DateTime    @default(now())
  status     QueueStatus @default(WAITING)

  // Relations
  machine    Machine     @relation(fields: [machineId], references: [id])
  user       User        @relation(fields: [userId], references: [id])
}
